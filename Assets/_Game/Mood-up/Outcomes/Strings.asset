  m_Script: {fileID: 11500000, guid: d75238216f0110443bc0c4584a805f93, type: 3}
  m_Name: Strings
  m_EditorClassIdentifier: Assembly-CSharp::Outcomes
  mySprite: {fileID: 21300000, guid: ceda8c8b8bd1a76478c963084c997196, type: 3}
  OutcomeRef: 4
  myName: strings
  myDescription: "You are known for your composure and focus. Your calm presence
    grounds those around you. Yes, you like things organised, but not because you
    are rigid \u2013 the structure helps you feel and be steady. Yet beneath that
    collected exterior you hold a surprising emotional depth. People come to you
    looking for comfort and understanding, and they find plenty. You are tying the
    group together discreetly, like a steady melody that\u2019s easy to follow. There
    is no need to be loud for you: you shape the atmosphere in other ways that are
    felt long after the moment has passed.  "
